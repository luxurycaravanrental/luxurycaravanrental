<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxury Caravan Rental | Motorhome &amp; Vanity Van Rental Delhi</title>
<meta name="description" content="Luxury Caravan Rental offers premium caravans, luxury vanity vans, and motorhomes in Delhi for family trips, weddings, shoots, and outstation travel.">
<meta name="robots" content="index,follow">
<link rel="canonical" href="https://luxurycaravanrental.com/">
<meta property="og:title" content="Luxury Caravan Rental">
<meta property="og:type" content="https://github.com/luxurycaravanrental/luxurycaravanrental.git">
<meta property="og:url" content="https://luxurycaravanrental.com/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --night:      #0f1a1c;
    --night-2:    #16262a;
    --dusk:       #23383d;
    --amber:      #e8a33d;
    --amber-soft: #f2c26b;
    --sand:       #f4ede0;
    --sand-dim:   #cfc4ae;
    --line:       rgba(244,237,224,0.14);
    --radius:     2px;
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--night);
    color:var(--sand);
    font-family:'Manrope', sans-serif;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    margin:0;
    letter-spacing:-0.01em;
  }
  a{color:inherit;}
  img{max-width:100%;display:block;}

  .wrap{max-width:1080px;margin:0 auto;padding:0 24px;}

  /* ---- top bar ---- */
  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:22px 0;
    border-bottom:1px solid var(--line);
  }
  .brand{
    display:flex;align-items:center;gap:10px;
    font-family:'Fraunces', serif;
    font-size:1.15rem;
    font-weight:600;
    letter-spacing:0.01em;
  }
  .brand-mark{
    width:34px;height:34px;
    border:1px solid var(--amber);
    border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-size:1rem;
  }
  .topbar-actions{display:flex;gap:12px;}
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    padding:10px 18px;
    font-size:0.85rem;
    font-weight:700;
    text-decoration:none;
    border-radius:var(--radius);
    border:1px solid transparent;
    white-space:nowrap;
  }
  .btn-amber{background:var(--amber);color:var(--night);}
  .btn-amber:hover{background:var(--amber-soft);}
  .btn-ghost{border-color:var(--line);color:var(--sand);}
  .btn-ghost:hover{border-color:var(--amber);color:var(--amber-soft);}

  /* ---- hero ---- */
  .hero{
    padding:96px 0 80px;
    position:relative;
    overflow:hidden;
  }
  .hero-eyebrow{
    color:var(--amber);
    font-size:0.75rem;
    letter-spacing:0.18em;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:18px;
  }
  .hero h1{
    font-size:clamp(2.4rem, 5vw, 4rem);
    max-width:14ch;
    line-height:1.05;
  }
  .hero h1 em{
    font-style:italic;
    color:var(--amber-soft);
  }
  .hero p{
    max-width:46ch;
    color:var(--sand-dim);
    font-size:1.05rem;
    margin-top:22px;
  }
  .hero-actions{
    display:flex;flex-wrap:wrap;gap:14px;
    margin-top:34px;
  }

  /* road / route signature graphic */
  .route{
    margin-top:64px;
    position:relative;
    padding-top:28px;
  }
  .route-line{
    position:absolute;top:34px;left:0;right:0;height:1px;
    background:repeating-linear-gradient(to right, var(--sand-dim) 0 10px, transparent 10px 20px);
    opacity:0.5;
  }
  .route-stops{
    display:flex;justify-content:space-between;
    position:relative;
    overflow-x:auto;
    gap:8px;
    padding-bottom:6px;
  }
  .route-stop{
    flex:0 0 auto;
    text-align:center;
    min-width:64px;
  }
  .route-dot{
    width:9px;height:9px;border-radius:50%;
    background:var(--amber);
    margin:0 auto 10px;
    box-shadow:0 0 0 4px rgba(232,163,61,0.15);
  }
  .route-stop span{
    font-size:0.72rem;
    color:var(--sand-dim);
    letter-spacing:0.02em;
  }

  /* ---- section shell ---- */
  section{padding:64px 0;border-top:1px solid var(--line);}
  .eyebrow{
    color:var(--amber);
    font-size:0.72rem;
    letter-spacing:0.16em;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:14px;
  }
  .section-title{font-size:clamp(1.6rem,3vw,2.1rem);max-width:20ch;}
  .section-lede{
    color:var(--sand-dim);
    max-width:60ch;
    margin-top:16px;
    font-size:1rem;
  }

  /* ---- services ---- */
  .services-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(230px,1fr));
    gap:1px;
    margin-top:40px;
    background:var(--line);
    border:1px solid var(--line);
  }
  .service-card{
    background:var(--night);
    padding:26px 22px;
    display:flex;
    align-items:center;
    gap:14px;
  }
  .service-icon{font-size:1.4rem;}
  .service-name{font-size:0.95rem;font-weight:600;}

  /* ---- destinations ---- */
  .dest-cols{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:48px;
    margin-top:40px;
  }
  .dest-col h3{
    font-size:1rem;
    font-family:'Manrope',sans-serif;
    font-weight:800;
    letter-spacing:0.03em;
    text-transform:uppercase;
    color:var(--amber-soft);
    margin-bottom:18px;
  }
  .dest-list{list-style:none;margin:0;padding:0;}
  .dest-list li{
    padding:12px 0;
    border-bottom:1px solid var(--line);
    font-family:'Fraunces',serif;
    font-size:1.05rem;
  }
  .dest-list li span{
    display:block;
    font-family:'Manrope',sans-serif;
    font-size:0.8rem;
    color:var(--sand-dim);
    margin-top:2px;
  }

  /* ---- contact ---- */
  .contact-card{
    margin-top:40px;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  .contact-item{
    background:var(--night-2);
    padding:28px 24px;
  }
  .contact-item .label{
    font-size:0.7rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--sand-dim);
    margin-bottom:10px;
  }
  .contact-item .value{
    font-family:'Fraunces',serif;
    font-size:1.15rem;
    color:var(--amber-soft);
    word-break:break-word;
  }
  .contact-item a{text-decoration:none;}
  .contact-item a:hover{text-decoration:underline;}

  footer{
    border-top:1px solid var(--line);
    padding:36px 0;
    display:flex;justify-content:space-between;align-items:center;
    flex-wrap:wrap;gap:12px;
    color:var(--sand-dim);
    font-size:0.85rem;
  }
  footer a{text-decoration:none;color:var(--sand-dim);}
  footer a:hover{color:var(--amber-soft);}

  @media (max-width:640px){
    .dest-cols{grid-template-columns:1fr;}
    .topbar{flex-direction:column;align-items:flex-start;gap:14px;}
    .topbar-actions{width:100%;}
    .btn{flex:1;justify-content:center;}
  }
</style>
</head>
